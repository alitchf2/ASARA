{
  "version": 1,
  "paths": {
    "/users/me": {
      "name": "/users/me",
      "lambdaFunction": "UpdateUserProfile",
      "permissions": {
        "setting": "private",
        "auth": [
          "update"
        ]
      }
    },
    "/colors/detect": {
      "name": "/colors/detect",
      "lambdaFunction": "DetectColor",
      "permissions": {
        "setting": "protected",
        "auth": [
          "create"
        ],
        "guest": [
          "create"
        ]
      }
    }
  }
}